@model IReadOnlyList<MedicalTimelineItemViewModel>

@if (Model.Count == 0)
{
    <p class="timeline-copy">Kayıtlı geçmiş bulunmuyor.</p>
}
else
{
    <ol class="timeline-list">
    @foreach (var item in Model)
    {
        <li class="@item.Tone">
            <article class="timeline-entry">
                <div class="timeline-meta">@item.OccurredAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm") · @item.Category</div>
                <h3>@item.Title</h3>
                <p class="timeline-copy">@item.Detail</p>
            </article>
        </li>
    }
    </ol>
}
