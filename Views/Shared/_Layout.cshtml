@using SmartCareApp.Models
@{
    var isAdmin = User.IsInRole(PortalRoles.Admin);
    var isDoctor = User.IsInRole(PortalRoles.Doctor);
    var isPatient = User.IsInRole(PortalRoles.Patient);
    var homeUrl = isAdmin
        ? Url.Action("Index", "Admin")
        : isDoctor
            ? Url.Action("Index", "DoctorPortal")
            : isPatient
                ? Url.Action("Index", "PatientPortal")
                : Url.Action("Index", "Home");
    var subtitle = isAdmin
        ? "Yönetim paneli"
        : isDoctor
            ? "Doktor paneli"
            : isPatient
                ? "Hasta paneli"
                : "Giriş";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartCareApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="shell-header">
        <nav class="navbar navbar-expand-lg shell-nav">
            <div class="container-xxl">
                <a class="navbar-brand shell-brand" href="@homeUrl">
                    <span class="brand-mark">SC</span>
                    <span>
                        <strong>SmartCare</strong>
                        <small>@subtitle</small>
                    </span>
                </a>
                <button class="navbar-toggler shell-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav me-auto">
                            @if (isAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">Genel Bakış</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Patients" asp-action="Index">Hastalar</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Doctors" asp-action="Index">Doktorlar</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Appointments" asp-action="Index">Randevular</a>
                                </li>
                            }
                            else if (isDoctor)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="DoctorPortal" asp-action="Index">Doktor Paneli</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Patients" asp-action="Create">Hasta Kaydı</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Patients" asp-action="Index">Hastalar</a>
                                </li>
                            }
                            else if (isPatient)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="PatientPortal" asp-action="Index">Hasta Paneli</a>
                                </li>
                            }
                        </ul>

                        <form asp-controller="Auth" asp-action="Logout" method="post" class="nav-logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link nav-logout-button">Çıkış</button>
                        </form>
                    }
                    else
                    {
                        <div class="ms-auto">
                            <a class="text-link" asp-controller="Admin" asp-action="Index">Yönetici</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="shell-backdrop"></div>

    <div class="container-xxl">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="status-banner">@statusMessage</div>
        }

        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="shell-footer">
        <div class="container-xxl d-flex flex-column flex-lg-row justify-content-between gap-2">
            <span>&copy; 2026 SmartCareApp</span>
            <span>Rol bazlı hasta ve doktor portalı</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
